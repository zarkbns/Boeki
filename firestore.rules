rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net (default-deny catch-all)
    match /{document=**} {
      allow read, write: if false;
    }

    // Standard high-reliability helper guards
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Rules for trading strategies
    match /trading_strategies/{stratId} {
      allow read, write: if true;
    }

    // Rules for conversations
    match /conversations/{convId} {
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // Rules for global curated strategies
    match /global_strategies/{globalId} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == "JFWUyAe7nxeoyhooaPtTH3eEFWE3";
    }

    // Rules for sessions
    match /sessions/{sessionId} {
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow write: if isSignedIn() && (
        (request.method == "create" && incoming().userId == request.auth.uid) ||
        (request.method != "create" && existing().userId == request.auth.uid)
      );
    }
  }
}
