rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net (default-deny catch-all)
    match /{document=**} {
      allow read, write: if false;
    }

    // Standard high-reliability helper guards
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Rules for trading strategies
    match /trading_strategies/{stratId} {
      // Allow read and write operations so the server-side integration can execute correctly
      allow read, write: if true;
    }

    // Rules for conversations
    match /conversations/{convId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && existing().userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && existing().userId == request.auth.uid && incoming().userId == request.auth.uid;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
