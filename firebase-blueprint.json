{
  "entities": {
    "TradingStrategy": {
      "title": "Trading Strategy Profile",
      "description": "Structured trading setup parameters extracted from technical video analysis.",
      "type": "object",
      "properties": {
        "strategyName": { "type": "string" },
        "timeframe": { "type": "string" },
        "indicators": {
          "type": "array",
          "items": { "type": "string" }
        },
        "entryConditionsLong": { "type": "string" },
        "entryConditionsShort": { "type": "string" },
        "entryConditions": { "type": "string" },
        "exitConditions": { "type": "string" },
        "riskRules": { "type": "string" },
        "rawRulesText": { "type": "string" },
        "videoId": { "type": "string" },
        "videoUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": [
        "strategyName",
        "timeframe",
        "indicators",
        "exitConditions"
      ]
    },
    "Conversation": {
      "title": "Conversation History",
      "description": "User's chat session history containing indicator queries and AI generated messages.",
      "type": "object",
      "properties": {
        "topic": { "type": "string" },
        "timestamp": { "type": "string" },
        "indicators": {
          "type": "array",
          "items": { "type": "string" }
        },
        "messages": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "messages"]
    },
    "Session": {
      "title": "User Session Memory",
      "description": "Persistent session context storing chat logs and metadata.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "title": { "type": "string" },
        "messages": {
          "type": "array",
          "items": { "type": "object" }
        }
      },
      "required": ["userId", "createdAt", "title", "messages"]
    },
    "GlobalStrategy": {
      "title": "Global Curated Strategy",
      "description": "Global strategy prepared by administrator from YouTube video parsing.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "strategyData": {
          "type": "array",
          "items": { "type": "object" }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "strategyData", "createdAt"]
    }
  },
  "firestore": {
    "trading_strategies/{stratId}": {
      "schema": "TradingStrategy",
      "description": "Stores individual structured trading strategies extracted by Gemini"
    },
    "conversations/{convId}": {
      "schema": "Conversation",
      "description": "Stores individual conversational context and messages for each user."
    },
    "sessions/{sessionId}": {
      "schema": "Session",
      "description": "Persistent user chats and session memory"
    },
    "global_strategies/{globalId}": {
      "schema": "GlobalStrategy",
      "description": "Publicly readable collection of curated trading strategies saved by Admin"
    }
  }
}
